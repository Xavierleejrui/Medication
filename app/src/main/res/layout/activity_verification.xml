<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview - fills top portion -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dark overlay - top -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toTopOf="@id/guideBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dark overlay - left -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="@id/guideBox"
        app:layout_constraintBottom_toBottomOf="@id/guideBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideBox" />

    <!-- Dark overlay - right -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="@id/guideBox"
        app:layout_constraintBottom_toBottomOf="@id/guideBox"
        app:layout_constraintStart_toEndOf="@id/guideBox"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dark overlay - bottom -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toBottomOf="@id/guideBox"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Guide Box - transparent center with white border -->
    <!-- Change from 260dp to 200dp -->
    <View
        android:id="@+id/guideBox"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/guide_box_border"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Instruction text above guide box -->
    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fill the box with your pill"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#80000000"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/guideBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Zoom controls for small pills -->
    <LinearLayout
        android:id="@+id/verifyZoomControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#80000000"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp">

        <Button
            android:id="@+id/verifyZoomOutBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="-"
            android:textSize="18sp"
            android:padding="0dp" />

        <TextView
            android:id="@+id/verifyZoomLabel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="1x"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/verifyZoomInBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="+"
            android:textSize="18sp"
            android:padding="0dp" />

    </LinearLayout>
    <!-- Bottom Results Panel -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Status Icon -->
        <TextView
            android:id="@+id/statusIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="40sp" />

        <!-- Result Text -->
        <TextView
            android:id="@+id/resultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Place pill in box, then tap verify"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Medication Name -->
        <TextView
            android:id="@+id/medicationNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Similarity Score -->
        <TextView
            android:id="@+id/similarityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Progress Bar (shown during multi-shot capture) -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <!-- Progress Text -->
        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Capturing photo 1/3..."
            android:textSize="13sp"
            android:textColor="#666666"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <!-- Verify Button -->
        <Button
            android:id="@+id/verifyButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="VERIFY PILL"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>